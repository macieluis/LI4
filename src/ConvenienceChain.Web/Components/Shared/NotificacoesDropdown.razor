@using ConvenienceChain.Core.Entities
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Web.Services
@inject INotificationService NotifSvc
@inject SessionService Session

@if (Session.IsAuthenticated)
{
    <div class="dropdown">
        <button class="btn btn-link text-white position-relative p-0 me-2"
                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                @onclick="CarregarAsync">
            <i class="bi bi-bell fs-5"></i>
            @if (_naoLidas is not null && _naoLidas.Any())
            {
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                    @_naoLidas.Count()
                </span>
            }
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow" style="min-width:340px;max-width:380px">
            <li class="px-3 py-2 d-flex justify-content-between align-items-center border-bottom">
                <strong class="small">Notificações</strong>
                @if (_naoLidas is not null && _naoLidas.Any())
                {
                    <span class="badge bg-secondary">@_naoLidas.Count() não lida(s)</span>
                }
            </li>

            @if (_naoLidas is null)
            {
                <li class="px-3 py-3 text-muted small text-center">A carregar…</li>
            }
            else if (!_naoLidas.Any())
            {
                <li class="px-3 py-3 text-muted small text-center">
                    <i class="bi bi-check2-circle fs-4 d-block mb-1 opacity-50"></i>
                    Sem notificações novas
                </li>
            }
            else
            {
                @foreach (var n in _naoLidas.Take(10))
                {
                    <li class="border-bottom">
                        <button type="button"
                                class="btn btn-link w-100 text-start text-decoration-none text-dark p-0"
                                style="white-space:normal"
                                @onclick="() => MarcarAsync(n.Id)">
                            <div class="px-3 py-2 hover-bg">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-1">
                                    <span class="badge @CorTipo(n.Tipo)" style="font-size:.65rem">@n.Tipo</span>
                                    <span class="text-muted" style="font-size:.7rem">
                                        @n.DataHora.ToLocalTime().ToString("dd/MM HH:mm")
                                    </span>
                                </div>
                                <div class="small" style="line-height:1.35;word-break:break-word">@n.Mensagem</div>
                            </div>
                        </button>
                    </li>
                }
                @if (_naoLidas.Count() > 10)
                {
                    <li class="px-3 py-2 text-muted text-center small border-top">
                        +@(_naoLidas.Count() - 10) mais notificações
                    </li>
                }
            }
        </ul>
    </div>
}

@code {
    private IEnumerable<Notificacao>? _naoLidas;

    protected override async Task OnInitializedAsync() => await CarregarAsync();

    private async Task CarregarAsync()
    {
        if (!Session.IsAuthenticated || Session.UserId is null) return;
        _naoLidas = await NotifSvc.GetNaoLidasAsync(Session.UserId);
    }

    private async Task MarcarAsync(int id)
    {
        await NotifSvc.MarcarComoLidaAsync(id);
        await CarregarAsync();
    }

    private static string CorTipo(string tipo) => tipo switch
    {
        "Error"   => "bg-danger",
        "Warning" => "bg-warning text-dark",
        _         => "bg-info text-dark"
    };
}
