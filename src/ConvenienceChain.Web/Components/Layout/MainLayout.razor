@inherits LayoutComponentBase
@inject ConvenienceChain.Web.Services.SessionService Session
@inject NavigationManager Nav

@if (!Session.IsAuthenticated)
{
    @* Não renderiza nada — OnInitialized redireciona para /login *@
}
else
{
<div class="d-flex min-vh-100">
    <!-- Sidebar -->
    <nav class="sidebar d-flex flex-column flex-shrink-0 p-3 text-white">
        <div class="brand mb-4">
            <i class="bi bi-shop-window fs-4 me-2"></i>
            <span class="fw-bold">SGCLC</span>
            <div class="text-muted small">QuickMart</div>
        </div>

        <ul class="nav nav-pills flex-column mb-auto gap-1">
            @* Dashboard – todos vêem *@
            <li><NavLink class="nav-link text-white" href="/dashboard" Match="NavLinkMatch.All"><i class="bi bi-speedometer2 me-2"></i>Dashboard</NavLink></li>

            @* POS – Funcionário e Gerente *@
            @if (Session.IsFuncionario || Session.IsGerenteLoja)
            {
                <li><NavLink class="nav-link text-white" href="/pos"><i class="bi bi-cart3 me-2"></i>Ponto de Venda</NavLink></li>
            }

            @* Stock – Gerente e Gestor *@
            @if (Session.IsGerenteLoja || Session.IsGestorCadeia)
            {
                <li><NavLink class="nav-link text-white" href="/stock"><i class="bi bi-boxes me-2"></i>Stock</NavLink></li>
            }

            @* Encomendas – Gerente e Gestor *@
            @if (Session.IsGerenteLoja || Session.IsGestorCadeia)
            {
                <li><NavLink class="nav-link text-white" href="/encomendas"><i class="bi bi-truck me-2"></i>Encomendas</NavLink></li>
            }

            @* Faturas – Gerente e Gestor *@
            @if (Session.IsGerenteLoja || Session.IsGestorCadeia)
            {
                <li><NavLink class="nav-link text-white" href="/faturas"><i class="bi bi-receipt me-2"></i>Faturas</NavLink></li>
            }

            @* Gestão Central – só Gestor da Cadeia *@
            @if (Session.IsGestorCadeia)
            {
                <li class="mt-3 px-2" style="font-size:.7rem;color:#6b7280;text-transform:uppercase;letter-spacing:.08em">Gestão Central</li>
                <li><NavLink class="nav-link text-white" href="/relatorios"><i class="bi bi-bar-chart-line me-2"></i>Relatórios</NavLink></li>
                <li><NavLink class="nav-link text-white" href="/consolidacao"><i class="bi bi-arrow-repeat me-2"></i>Consolidação</NavLink></li>
                <li><NavLink class="nav-link text-white" href="/admin/utilizadores"><i class="bi bi-people me-2"></i>Utilizadores</NavLink></li>
            }

            @* Relatórios – Gerente *@
            @if (Session.IsGerenteLoja)
            {
                <li class="mt-3 px-2" style="font-size:.7rem;color:#6b7280;text-transform:uppercase;letter-spacing:.08em">Relatórios e Gestão</li>
                <li><NavLink class="nav-link text-white" href="/relatorios"><i class="bi bi-bar-chart-line me-2"></i>Relatórios</NavLink></li>
                <li><NavLink class="nav-link text-white" href="/admin/utilizadores"><i class="bi bi-person-gear me-2"></i>Funcionários</NavLink></li>
            }
        </ul>

        <div class="border-top pt-3 mt-3">
            <div class="d-flex align-items-center gap-2 mb-2">
                <div class="avatar-circle"><i class="bi bi-person-fill"></i></div>
                <div>
                    <div class="small fw-semibold">@Session.Nome</div>
                    <div class="text-muted" style="font-size:.75rem">@Session.Papel</div>
                </div>
            </div>
            <button class="btn btn-sm btn-outline-light w-100" @onclick="Logout">
                <i class="bi bi-box-arrow-right me-1"></i> Sair
            </button>
        </div>
    </nav>

    <!-- Conteúdo principal -->
    <main class="flex-grow-1 p-4 bg-light">
        @Body
    </main>
</div>
}

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsAuthenticated)
            Nav.NavigateTo("/login", replace: true);
    }

    protected override void OnParametersSet()
    {
        if (!Session.IsAuthenticated)
            Nav.NavigateTo("/login", replace: true);
    }

    private void Logout()
    {
        Session.Logout();
        Nav.NavigateTo("/login", forceLoad: true);
    }
}
