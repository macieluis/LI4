@page "/pos"
@using ConvenienceChain.Core.DTOs
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Web.Services
@inject IProdutoService ProdutoSvc
@inject ISalesService SalesSvc
@inject IStockService StockSvc
@inject SessionService Session

<PageTitle>Ponto de Venda – SGCLC</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-cart3 me-2 text-primary"></i>Ponto de Venda</h1>
    <p class="text-muted mb-0">Loja: <strong>@Session.Nome</strong> | Funcionário: <strong>@Session.Nome</strong></p>
</div>

@if (vendaConcluida is not null)
{
    <div class="alert alert-success d-flex align-items-start gap-3">
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div>
            <strong>Venda concluída!</strong> Total: <strong>€@vendaConcluida.Total.ToString("N2")</strong>
            <br /><small>Venda #@vendaConcluida.Id registada às @vendaConcluida.DataHora.ToString("HH:mm")</small>
        </div>
        <button class="btn btn-sm btn-success ms-auto" @onclick="NovaVenda">Nova Venda</button>
    </div>
}

<div class="row g-4">
    <!-- Pesquisa de produtos -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h6 class="fw-semibold mb-3"><i class="bi bi-search me-2"></i>Pesquisar Produto</h6>
                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                    <input class="form-control" placeholder="Código ou nome..." @bind="pesquisa" @oninput="PesquisarProdutos" />
                </div>

                @if (resultados.Any())
                {
                    <div class="list-group list-group-flush" style="max-height:350px;overflow-y:auto">
                        @foreach (var p in resultados)
                        {
                            <button class="list-group-item list-group-item-action pos-product-row d-flex justify-content-between"
                                    @onclick="() => AdicionarAoCarrinho(p)">
                                <div>
                                    <div class="fw-medium small">@p.Nome</div>
                                    <div class="text-muted" style="font-size:.75rem">@p.Codigo | @p.Categoria?.Nome</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-primary">€@p.PrecoBaseVenda.ToString("N2")</div>
                                    <div class="text-muted" style="font-size:.7rem">por @p.UnidadeMedida</div>
                                </div>
                            </button>
                        }
                    </div>
                }
                else if (!string.IsNullOrEmpty(pesquisa))
                {
                    <p class="text-muted text-center py-3"><i class="bi bi-search me-1"></i>Nenhum produto encontrado.</p>
                }
            </div>
        </div>
    </div>

    <!-- Carrinho -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h6 class="fw-semibold mb-3"><i class="bi bi-cart-check me-2"></i>Carrinho</h6>

                @if (!carrinho.Any())
                {
                    <div class="text-center text-muted py-5 flex-grow-1">
                        <i class="bi bi-cart3 fs-1 d-block mb-2 opacity-25"></i>
                        Adicione produtos ao carrinho
                    </div>
                }
                else
                {
                    <div class="table-responsive flex-grow-1">
                        <table class="table table-sm align-middle">
                            <thead><tr><th>Produto</th><th style="width:80px">Qtd</th><th class="text-end">Preço</th><th class="text-end">Total</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var item in carrinho)
                                {
                                    <tr>
                                        <td class="small">@item.Nome</td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="1"
                                                   value="@item.Quantidade"
                                                   @onchange="e => AlterarQuantidade(item, int.Parse(e.Value!.ToString()!))" />
                                        </td>
                                        <td class="text-end small">€@item.PrecoUnit.ToString("N2")</td>
                                        <td class="text-end small fw-semibold">€@((item.Quantidade * item.PrecoUnit).ToString("N2"))</td>
                                        <td><button class="btn btn-sm btn-link text-danger p-0" @onclick="() => RemoverDoCarrinho(item)"><i class="bi bi-trash3"></i></button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="border-top pt-3 mt-2">
                        <div class="row g-2 align-items-center mb-3">
                            <div class="col-auto small text-muted">Desconto (€):</div>
                            <div class="col-3">
                                <input type="number" class="form-control form-control-sm" min="0" step="0.01"
                                       @bind="desconto" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-end">
                            <div>
                                <div class="text-muted small">Subtotal: €@Subtotal.ToString("N2")</div>
                                @if (desconto > 0)
                                {
                                    <div class="text-danger small">Desconto: -€@desconto.ToString("N2")</div>
                                }
                                <div class="cart-total">Total: €@Total.ToString("N2")</div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="NovaVenda">
                                    <i class="bi bi-trash3 me-1"></i>Limpar
                                </button>
                                <button class="btn btn-success" @onclick="ConfirmarVenda" disabled="@(a_processar || !carrinho.Any())">
                                    @if (a_processar) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-check-circle me-1"></i>Confirmar Venda
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(erroVenda))
                        {
                            <div class="alert alert-danger mt-2 py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>@erroVenda</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string pesquisa = "";
    private List<Core.Entities.Produto> resultados = new();
    private List<CarrinhoItem> carrinho = new();
    private decimal desconto = 0;
    private bool a_processar;
    private string? erroVenda;
    private VendaDto? vendaConcluida;

    private decimal Subtotal => carrinho.Sum(i => i.Quantidade * i.PrecoUnit);
    private decimal Total => Math.Max(0, Subtotal - desconto);

    private async Task PesquisarProdutos(ChangeEventArgs e)
    {
        pesquisa = e.Value?.ToString() ?? "";
        if (pesquisa.Length < 2) { resultados.Clear(); return; }
        var todos = await ProdutoSvc.SearchAsync(pesquisa);
        resultados = todos.Take(8).ToList();
    }

    private void AdicionarAoCarrinho(Core.Entities.Produto p)
    {
        var existing = carrinho.FirstOrDefault(i => i.ProdutoId == p.Id);
        if (existing is not null) { existing.Quantidade++; return; }
        carrinho.Add(new CarrinhoItem { ProdutoId = p.Id, Nome = p.Nome, PrecoUnit = p.PrecoBaseVenda, Quantidade = 1 });
    }

    private void AlterarQuantidade(CarrinhoItem item, int qty)
    {
        if (qty <= 0) carrinho.Remove(item);
        else item.Quantidade = qty;
    }

    private void RemoverDoCarrinho(CarrinhoItem item) => carrinho.Remove(item);

    private async Task ConfirmarVenda()
    {
        a_processar = true; erroVenda = null;
        try
        {
            var createDto = new CreateVendaDto(
                Session.LojaId!.Value,
                Session.UserId!,
                carrinho.Select(i => new LinhaVendaDto(i.ProdutoId, i.Quantidade, i.PrecoUnit, 0)));
            vendaConcluida = await SalesSvc.CreateSaleAsync(createDto);
            carrinho.Clear();
            desconto = 0;
        }
        catch (Exception ex) { erroVenda = ex.Message; }
        finally { a_processar = false; }
    }

    private void NovaVenda() { carrinho.Clear(); desconto = 0; vendaConcluida = null; erroVenda = null; pesquisa = ""; resultados.Clear(); }

    private class CarrinhoItem
    {
        public int ProdutoId { get; set; }
        public string Nome { get; set; } = "";
        public decimal PrecoUnit { get; set; }
        public int Quantidade { get; set; }
    }
}
