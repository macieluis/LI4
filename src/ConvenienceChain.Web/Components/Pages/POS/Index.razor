@page "/pos"
@using ConvenienceChain.Core.DTOs
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Web.Services
@inject IProdutoService ProdutoSvc
@inject ISalesService SalesSvc
@inject IStockService StockSvc
@inject IFaturaService FaturaSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Ponto de Venda – SGCLC</PageTitle>

@if (!Session.IsAuthenticated || Session.IsGestorCadeia)
{
    Nav.NavigateTo("/dashboard");
    return;
}

<div class="page-header">
    <h1><i class="bi bi-cart3 me-2 text-primary"></i>Ponto de Venda</h1>
    <p class="text-muted mb-0">Loja: <strong>@Session.LojaId</strong> | Utilizador: <strong>@Session.Nome</strong></p>
</div>

@if (vendaConcluida is not null)
{
    <div class="alert alert-success d-flex align-items-start gap-3">
        <i class="bi bi-check-circle-fill fs-4"></i>
        <div>
            <strong>Venda concluída!</strong> Total: <strong>€@vendaConcluida.Total.ToString("N2")</strong>
            <br /><small>Venda #@vendaConcluida.Id registada às @vendaConcluida.DataHora.ToString("HH:mm")</small>
        </div>
        <button class="btn btn-sm btn-success ms-auto" @onclick="NovaVenda">Nova Venda</button>
    </div>
}

<div class="row g-4">
    <!-- Pesquisa + Tabela de produtos -->
    <div class="col-md-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h6 class="fw-semibold mb-3"><i class="bi bi-search me-2"></i>Produtos Disponíveis</h6>

                <!-- Barra de pesquisa -->
                <div class="input-group mb-2">
                    <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                    <input id="pos-search" class="form-control" placeholder="Pesquisar por nome, código ou categoria..."
                           @bind="pesquisa" @oninput="PesquisarProdutos" autocomplete="off" />
                    @if (!string.IsNullOrEmpty(pesquisa))
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="LimparPesquisa" title="Limpar">
                            <i class="bi bi-x"></i>
                        </button>
                    }
                </div>

                <!-- Tabela de produtos com stock > 0 -->
                <div class="table-responsive flex-grow-1" style="max-height:420px;overflow-y:auto">
                    @if (a_carregar_produtos)
                    {
                        <div class="text-center text-muted py-4">
                            <span class="spinner-border spinner-border-sm me-2"></span>A carregar...
                        </div>
                    }
                    else if (!produtosComStock.Any())
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-box-seam fs-2 d-block mb-2 opacity-25"></i>
                            @if (string.IsNullOrEmpty(pesquisa))
                            {
                                <span>Sem produtos com stock disponível.</span>
                            }
                            else
                            {
                                <span>Nenhum resultado para "<strong>@pesquisa</strong>".</span>
                            }
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover table-sm align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Produto</th>
                                    <th class="text-center" style="width:60px">Stock</th>
                                    <th class="text-end" style="width:75px">Preço</th>
                                    <th style="width:40px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in produtosComStock)
                                {
                                    <tr class="pos-product-row" style="cursor:pointer" @onclick="() => AdicionarAoCarrinhoPorStock(item)">
                                        <td>
                                            <div class="fw-medium small">@item.NomeProduto</div>
                                            <div class="text-muted" style="font-size:.72rem">@item.CodigoProduto
                                                @if (!string.IsNullOrEmpty(item.Categoria))
                                                {
                                                    <span class="badge bg-secondary ms-1" style="font-size:.65rem">@item.Categoria</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge @(item.EmAlerta ? "bg-warning text-dark" : "bg-success")">@item.Quantidade</span>
                                        </td>
                                        <td class="text-end small fw-semibold text-primary">€@((item.PrecoVendaLocal ?? item.PrecoBaseVenda).ToString("N2"))</td>
                                        <td class="text-center">
                                            <button class="btn btn-sm btn-outline-primary py-0 px-1" title="Adicionar"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => AdicionarAoCarrinhoPorStock(item)">
                                                <i class="bi bi-plus-lg"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Carrinho -->
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h6 class="fw-semibold mb-3"><i class="bi bi-cart-check me-2"></i>Carrinho
                    @if (carrinho.Any())
                    {
                        <span class="badge bg-primary ms-1">@carrinho.Count</span>
                    }
                </h6>

                @if (!carrinho.Any())
                {
                    <div class="text-center text-muted py-5 flex-grow-1">
                        <i class="bi bi-cart3 fs-1 d-block mb-2 opacity-25"></i>
                        Clique num produto para adicionar ao carrinho
                    </div>
                }
                else
                {
                    <div class="table-responsive flex-grow-1">
                        <table class="table table-sm align-middle">
                            <thead><tr><th>Produto</th><th style="width:80px">Qtd</th><th class="text-end">Preço</th><th class="text-end">Total</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var item in carrinho)
                                {
                                    <tr>
                                        <td class="small">@item.Nome</td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" min="1"
                                                   value="@item.Quantidade"
                                                   @onchange="e => AlterarQuantidade(item, int.Parse(e.Value!.ToString()!))" />
                                        </td>
                                        <td class="text-end small">€@item.PrecoUnit.ToString("N2")</td>
                                        <td class="text-end small fw-semibold">€@((item.Quantidade * item.PrecoUnit).ToString("N2"))</td>
                                        <td><button class="btn btn-sm btn-link text-danger p-0" @onclick="() => RemoverDoCarrinho(item)"><i class="bi bi-trash3"></i></button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="border-top pt-3 mt-2">
                        <div class="row g-2 align-items-center mb-3">
                            <div class="col-auto small text-muted">Desconto (€):</div>
                            <div class="col-3">
                                <input type="number" class="form-control form-control-sm" min="0" step="0.01"
                                       @bind="desconto" @bind:event="oninput" />
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-end">
                            <div>
                                <div class="text-muted small">Subtotal: €@Subtotal.ToString("N2")</div>
                                @if (desconto > 0)
                                {
                                    <div class="text-danger small">Desconto: -€@desconto.ToString("N2")</div>
                                }
                                <div class="cart-total">Total: €@Total.ToString("N2")</div>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="NovaVenda">
                                    <i class="bi bi-trash3 me-1"></i>Limpar
                                </button>
                                <button class="btn btn-success" @onclick="ConfirmarVenda" disabled="@(a_processar || !carrinho.Any())">
                                    @if (a_processar) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    <i class="bi bi-check-circle me-1"></i>Confirmar Venda
                                </button>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(erroVenda))
                        {
                            <div class="alert alert-danger mt-2 py-2 small"><i class="bi bi-exclamation-triangle me-1"></i>@erroVenda</div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string pesquisa = "";
    private List<StockDto> todosOsStocks = new();
    private List<StockDto> produtosComStock = new();
    private List<CarrinhoItem> carrinho = new();
    private decimal desconto = 0;
    private bool a_processar;
    private bool a_carregar_produtos = true;
    private string? erroVenda;
    private VendaDto? vendaConcluida;

    private decimal Subtotal => carrinho.Sum(i => i.Quantidade * i.PrecoUnit);
    private decimal Total => Math.Max(0, Subtotal - desconto);

    protected override async Task OnInitializedAsync()
    {
        a_carregar_produtos = true;
        if (Session.LojaId.HasValue)
        {
            todosOsStocks = (await StockSvc.GetStockLojaAsync(Session.LojaId.Value))
                .Where(s => s.Quantidade > 0)
                .OrderBy(s => s.NomeProduto)
                .ToList();
            produtosComStock = todosOsStocks;
        }
        a_carregar_produtos = false;
    }

    private void PesquisarProdutos(ChangeEventArgs e)
    {
        pesquisa = e.Value?.ToString() ?? "";
        AplicarFiltro();
    }

    private void LimparPesquisa()
    {
        pesquisa = "";
        produtosComStock = todosOsStocks;
    }

    private void AplicarFiltro()
    {
        if (string.IsNullOrWhiteSpace(pesquisa))
        {
            produtosComStock = todosOsStocks;
            return;
        }
        var q = Normalizar(pesquisa.Trim());
        produtosComStock = todosOsStocks.Where(s =>
            Normalizar(s.NomeProduto).Contains(q) ||
            Normalizar(s.CodigoProduto).Contains(q) ||
            (s.Categoria != null && Normalizar(s.Categoria).Contains(q))
        ).ToList();
    }

    /// <summary>Remove acentos e normaliza para lowercase. "café" → "cafe".</summary>
    private static string Normalizar(string s) =>
        new string(s.Normalize(System.Text.NormalizationForm.FormD)
            .Where(c => System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c)
                        != System.Globalization.UnicodeCategory.NonSpacingMark)
            .ToArray())
        .ToLowerInvariant();

    private void AdicionarAoCarrinhoPorStock(StockDto s)
    {
        var existing = carrinho.FirstOrDefault(i => i.ProdutoId == s.ProdutoId);
        if (existing is not null) { existing.Quantidade++; return; }
        carrinho.Add(new CarrinhoItem
        {
            ProdutoId = s.ProdutoId,
            Nome = s.NomeProduto,
            PrecoUnit = s.PrecoVendaLocal ?? s.PrecoBaseVenda,
            Quantidade = 1
        });
    }

    private void AlterarQuantidade(CarrinhoItem item, int qty)
    {
        if (qty <= 0) carrinho.Remove(item);
        else item.Quantidade = qty;
    }

    private void RemoverDoCarrinho(CarrinhoItem item) => carrinho.Remove(item);

    private async Task ConfirmarVenda()
    {
        a_processar = true; erroVenda = null;
        try
        {
            var linhas = carrinho.Select(i => new LinhaVendaDto(i.ProdutoId, i.Quantidade, i.PrecoUnit, 0)).ToList();
            var createDto = new CreateVendaDto(Session.LojaId!.Value, Session.UserId!, linhas);
            vendaConcluida = await SalesSvc.CreateSaleAsync(createDto);

            // Emitir fatura automaticamente
            var faturaDto = new EmitirFaturaDto(
                Session.LojaId!.Value,
                vendaConcluida.Id,
                "", "", "",  // consumidor final sem dados fiscais
                linhas.Select(l => new LinhaFaturaDto(
                    carrinho.FirstOrDefault(c => c.ProdutoId == l.ProdutoId)?.Nome ?? $"Produto {l.ProdutoId}",
                    l.Quantidade, l.PrecoUnitario, l.Desconto)));
            await FaturaSvc.EmitirAsync(faturaDto);

            // Recarregar stock após venda
            todosOsStocks = (await StockSvc.GetStockLojaAsync(Session.LojaId!.Value))
                .Where(s => s.Quantidade > 0)
                .OrderBy(s => s.NomeProduto)
                .ToList();
            AplicarFiltro();
            carrinho.Clear();
            desconto = 0;
        }
        catch (Exception ex) { erroVenda = ex.Message; }
        finally { a_processar = false; }
    }

    private void NovaVenda()
    {
        carrinho.Clear(); desconto = 0; vendaConcluida = null; erroVenda = null;
        pesquisa = ""; produtosComStock = todosOsStocks;
    }

    private class CarrinhoItem
    {
        public int ProdutoId { get; set; }
        public string Nome { get; set; } = "";
        public decimal PrecoUnit { get; set; }
        public int Quantidade { get; set; }
    }
}
