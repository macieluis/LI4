@page "/consolidacao"
@using ConvenienceChain.Core.DTOs
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Web.Services
@inject IConsolidacaoService ConsSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Consolidação – SGCLC</PageTitle>

@if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1><i class="bi bi-arrow-repeat me-2 text-primary"></i>Consolidação Diária</h1>
        <p class="text-muted mb-0">Encerramento e resumo de vendas por loja</p>
    </div>
    @if (Session.IsGestorCadeia)
    {
        <button class="btn btn-primary" @onclick="ConsolidarHoje" disabled="@a_consolidar">
            @if (a_consolidar) { <span class="spinner-border spinner-border-sm me-1"></span> }
            <i class="bi bi-play-circle me-1"></i>Consolidar Hoje
        </button>
    }
</div>

@if (!string.IsNullOrEmpty(mensagem))
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@mensagem
        <button type="button" class="btn-close" @onclick="() => mensagem = null"></button>
    </div>
}

@if (a_carregar)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else if (historico is not null && historico.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h6 class="fw-semibold mb-3"><i class="bi bi-clock-history me-2 text-primary"></i>Histórico de Consolidações</h6>
            <table class="table table-hover table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Loja</th>
                        <th class="text-end">Total Vendas</th>
                        <th class="text-end">Nº Transações</th>
                        <th>Executado em</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in historico.OrderByDescending(x => x.DataConsolidacao))
                    {
                        <tr>
                            <td>@c.DataConsolidacao.ToString("dd/MM/yyyy")</td>
                            <td class="small">@c.NomeLoja</td>
                            <td class="text-end fw-semibold">€@c.TotalVendas.ToString("N2")</td>
                            <td class="text-end">@c.NumeroTransacoes</td>
                            <td class="small text-muted">@c.DataHoraExecucao.ToString("dd/MM HH:mm")</td>
                            <td>
                                @if (c.Resultado == "Sucesso")
                                {
                                    <span class="badge bg-success">Sucesso</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger" title="@c.Erro">Falha</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-arrow-repeat fs-1 d-block mb-2 opacity-25"></i>
        Ainda não foram efetuadas consolidações. Clique em "Consolidar Hoje" para iniciar.
    </div>
}

@code {
    private IEnumerable<ConsolidacaoDto>? historico;
    private bool a_carregar = true;
    private bool a_consolidar;
    private string? mensagem;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        historico = await ConsSvc.GetHistoricoAsync();
        a_carregar = false;
    }

    private async Task ConsolidarHoje()
    {
        a_consolidar = true;
        await ConsSvc.ConsolidarTodasAsync(DateOnly.FromDateTime(DateTime.Today));
        historico = await ConsSvc.GetHistoricoAsync();
        mensagem = $"Consolidação de {DateTime.Today:dd/MM/yyyy} concluída com sucesso!";
        a_consolidar = false;
    }
}
