@page "/consolidacao"
@using ConvenienceChain.Core.DTOs
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Web.Services
@inject IConsolidacaoService ConsSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Consolidação – SGCLC</PageTitle>

@if (!Session.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1><i class="bi bi-arrow-repeat me-2 text-primary"></i>Consolidação Diária</h1>
        <p class="text-muted mb-0">Encerramento e resumo de vendas por loja</p>
    </div>
    @if (Session.IsGestorCadeia)
    {
        <button class="btn btn-primary" @onclick="AbrirModal">
            <i class="bi bi-play-circle me-1"></i>Executar Consolidação Manual
        </button>
    }
</div>

@if (_ultimoResumo is not null)
{
    var cor = _ultimoResumo.Falhas == 0 ? "success" : "warning";
    <div class="alert alert-@cor alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>
        Consolidação concluída: @_ultimoResumo.Sucessos loja(s) com sucesso
        @if (_ultimoResumo.Falhas > 0)
        {
            <span>, <strong>@_ultimoResumo.Falhas falha(s)</strong> (lojas: @string.Join(", ", _ultimoResumo.LojasComFalha)).</span>
        }
        else
        {
            <span>.</span>
        }
        <button type="button" class="btn-close" @onclick="() => _ultimoResumo = null"></button>
    </div>
}

@if (_aCarregar)
{
    <div class="d-flex justify-content-center my-5">
        <div class="spinner-border text-primary"></div>
    </div>
}
else if (_historico is not null && _historico.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h6 class="fw-semibold mb-3"><i class="bi bi-clock-history me-2 text-primary"></i>Histórico de Consolidações</h6>
            <table class="table table-hover table-sm">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Loja</th>
                        <th class="text-end">Total Vendas</th>
                        <th class="text-end">Nº Transações</th>
                        <th>Executado em</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _historico.OrderByDescending(x => x.DataConsolidacao).ThenBy(x => x.NomeLoja))
                    {
                        <tr>
                            <td>@c.DataConsolidacao.ToString("dd/MM/yyyy")</td>
                            <td class="small">@c.NomeLoja</td>
                            <td class="text-end fw-semibold">€@c.TotalVendas.ToString("N2")</td>
                            <td class="text-end">@c.NumeroTransacoes</td>
                            <td class="small text-muted">@c.DataHoraExecucao.ToString("dd/MM HH:mm")</td>
                            <td><span class="badge bg-@CorResultado(c.Resultado)" title="@c.Erro">@c.Resultado</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-arrow-repeat fs-1 d-block mb-2 opacity-25"></i>
        Ainda não foram efetuadas consolidações.
        @if (Session.IsGestorCadeia) { <span>Clique em <strong>Executar Consolidação Manual</strong> para iniciar.</span> }
    </div>
}

@if (_mostrarModal)
{
    <div class="modal show d-block" tabindex="-1" role="dialog" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-play-circle me-2"></i>Consolidação Manual</h5>
                    <button type="button" class="btn-close" @onclick="FecharModal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label fw-medium">Data a consolidar</label>
                    <input type="date" class="form-control" @bind="_dataEscolhida" />
                    <div class="form-text">Serão consolidadas todas as lojas ativas nesta data.</div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FecharModal" disabled="@_aExecutar">Cancelar</button>
                    <button class="btn btn-primary" @onclick="ExecutarAsync" disabled="@_aExecutar">
                        @if (_aExecutar) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Executar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private IEnumerable<ConsolidacaoDto>? _historico;
    private bool _aCarregar = true;
    private bool _aExecutar;
    private bool _mostrarModal;
    private DateTime _dataEscolhida = DateTime.Today.AddDays(-1);
    private ConsolidacaoResumoDto? _ultimoResumo;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated) return;
        _historico = await ConsSvc.GetHistoricoAsync();
        _aCarregar = false;
    }

    private void AbrirModal()
    {
        _ultimoResumo = null;
        _dataEscolhida = DateTime.Today.AddDays(-1);
        _mostrarModal = true;
    }

    private void FecharModal() => _mostrarModal = false;

    private async Task ExecutarAsync()
    {
        _aExecutar = true;
        try
        {
            _ultimoResumo = await ConsSvc.ConsolidarTodasAsync(DateOnly.FromDateTime(_dataEscolhida), Session.UserId);
            _historico = await ConsSvc.GetHistoricoAsync();
        }
        finally
        {
            _aExecutar = false;
            _mostrarModal = false;
        }
    }

    private static string CorResultado(string r) => r switch
    {
        "Sucesso" => "success",
        "Parcial" => "warning",
        "Falha" => "danger",
        _ => "secondary"
    };
}
