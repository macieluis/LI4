@page "/stock"
@using ConvenienceChain.Core.DTOs
@using ConvenienceChain.Core.Entities
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Web.Services
@inject IStockService StockSvc
@inject ILojaRepository LojaRepo
@inject SessionService Session

<PageTitle>Gestão de Stock – SGCLC</PageTitle>

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h1><i class="bi bi-boxes me-2 text-primary"></i>Gestão de Stock</h1>
        <p class="text-muted mb-0">
            @if (Session.IsGestorCadeia)
            { <span>Selecione uma loja para visualizar o stock</span> }
            else
            { <span>Loja: Id @Session.LojaId</span> }
        </p>
    </div>
    <button class="btn btn-outline-secondary btn-sm" @onclick="ExportarCsv">
        <i class="bi bi-download me-1"></i>Exportar CSV
    </button>
</div>

<!-- Alertas globais -->
@if (alertas.Any())
{
    <div class="alert stock-alert mb-3">
        <strong><i class="bi bi-exclamation-triangle-fill me-2"></i>@alertas.Count() produto(s) abaixo do stock mínimo!</strong>
    </div>
}
@{
    var expirados  = todos.Where(s => s.DiasFimValidade.HasValue && s.DiasFimValidade.Value < 0).ToList();
    var aExpirar   = todos.Where(s => s.DiasFimValidade.HasValue && s.DiasFimValidade.Value >= 0 && s.DiasFimValidade.Value <= 30).ToList();
}
@if (expirados.Any())
{
    <div class="alert alert-danger mb-2"><i class="bi bi-x-octagon-fill me-2"></i><strong>@expirados.Count produto(s) EXPIRADO(S)!</strong> — @string.Join(", ", expirados.Select(s => s.NomeProduto))</div>
}
@if (aExpirar.Any())
{
    <div class="alert alert-warning mb-3"><i class="bi bi-clock-history me-2"></i><strong>@aExpirar.Count produto(s) a expirar em ≤30 dias</strong> — @string.Join(", ", aExpirar.Select(s => $"{s.NomeProduto} ({s.DiasFimValidade}d"))</div>
}

<!-- Filtros -->
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            @if (Session.IsGestorCadeia)
            {
                <div class="col-md-4">
                    <label class="form-label fw-medium small mb-1">Loja</label>
                    <select class="form-select form-select-sm" @bind="lojaIdSelecionada" @bind:after="OnLojaChanged">
                        <option value="0">-- Selecionar loja --</option>
                        @foreach (var l in todasAsLojas)
                        {
                            <option value="@l.Id">@l.Nome</option>
                        }
                    </select>
                </div>
            }
            <div class="col-md-4">
                <label class="form-label fw-medium small mb-1">Pesquisar</label>
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input class="form-control" placeholder="Produto, código ou categoria..."
                           value="@filtroNome"
                           @oninput="OnFiltroNomeInput" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-medium small mb-1">Estado</label>
                <select class="form-select form-select-sm" @bind="filtroAlerta" @bind:after="Filtrar">
                    <option value="">Todos</option>
                    <option value="alerta">Em alerta</option>
                    <option value="ok">Stock OK</option>
                    <option value="expirado">Expirados</option>
                    <option value="aExpirar">A expirar (≤30d)</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Tabela de stock -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (a_carregar)
        {
            <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (Session.IsGestorCadeia && lojaIdSelecionada == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-building fs-1 d-block mb-2 opacity-25"></i>
                Selecione uma loja para ver o respetivo stock.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Produto</th>
                            <th>Categoria</th>
                            <th class="text-center">Qtd. Atual</th>
                            <th class="text-center">Stock Mín.</th>
                            <th class="text-end">Preço Venda</th>
                            <th class="text-center">Validade</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!stockFiltrado.Any())
                        {
                            <tr><td colspan="8" class="text-center text-muted py-4">Nenhum produto encontrado.</td></tr>
                        }
                        @foreach (var s in stockFiltrado)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium small">@s.NomeProduto</div>
                                    <div class="text-muted" style="font-size:.72rem">@s.CodigoProduto</div>
                                </td>
                                <td class="small text-muted">@s.Categoria</td>
                                <td class="text-center fw-semibold @(s.EmAlerta ? "text-danger" : "text-success")">@s.Quantidade.ToString("0.###")</td>
                                <td class="text-center text-muted small">@s.StockMinimo.ToString("0.###")</td>
                                <td class="text-end small">€@((s.PrecoVendaLocal ?? s.PrecoBaseVenda).ToString("N2"))</td>
                                <td class="text-center">
                                    @if (!s.DataValidade.HasValue)
                                    {
                                        <span class="text-muted small">–</span>
                                    }
                                    else if (s.DiasFimValidade < 0)
                                    {
                                        <span class="badge bg-danger" title="@s.DataValidade?.ToString("dd/MM/yyyy")"><i class="bi bi-x-octagon me-1"></i>Expirado</span>
                                    }
                                    else if (s.DiasFimValidade <= 30)
                                    {
                                        <span class="badge bg-warning text-dark" title="@s.DataValidade?.ToString("dd/MM/yyyy")"><i class="bi bi-clock me-1"></i>@s.DiasFimValidade d</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">@s.DataValidade?.ToString("dd/MM/yyyy")</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (s.EmAlerta)
                                    {
                                        <span class="badge badge-pendente px-2 py-1"><i class="bi bi-exclamation-triangle me-1"></i>Alerta</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-rececionada px-2 py-1"><i class="bi bi-check-circle me-1"></i>OK</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => AbrirAjuste(s)" title="Ajuste Manual">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Modal: Ajuste de Stock -->
@if (produtoAjuste is not null)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4 shadow-lg">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2 text-primary"></i>Ajuste de Stock</h5>
                    <button class="btn-close" @onclick="() => produtoAjuste = null"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-semibold">@produtoAjuste.NomeProduto</p>
                    <p class="text-muted small">Quantidade atual: <strong>@produtoAjuste.Quantidade.ToString("0.###")</strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Variação <span class="text-muted">(+ entrada / - saída)</span></label>
                        <input type="number" class="form-control" step="0.001" @bind="ajusteVariacao" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Motivo <span class="text-danger">*</span></label>
                        <input class="form-control" placeholder="Ex: Quebra, Inventário, Devolução..." @bind="ajusteMotivo" />
                    </div>
                    @if (!string.IsNullOrEmpty(erroAjuste))
                    {
                        <div class="alert alert-danger py-2 small">@erroAjuste</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="() => produtoAjuste = null">Cancelar</button>
                    <button class="btn btn-primary btn-sm" @onclick="ConfirmarAjuste" disabled="@a_ajuste">
                        @if (a_ajuste) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirmar Ajuste
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<StockDto> todos = new();
    private List<StockDto> stockFiltrado = new();
    private IEnumerable<StockAlertaDto> alertas = Enumerable.Empty<StockAlertaDto>();
    private List<Loja> todasAsLojas = new();
    private int lojaIdSelecionada = 0;
    private string filtroNome = "", filtroAlerta = "";
    private bool a_carregar = true;

    private StockDto? produtoAjuste;
    private decimal ajusteVariacao;
    private string ajusteMotivo = "";
    private bool a_ajuste;
    private string? erroAjuste;

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsGestorCadeia)
        {
            todasAsLojas = (await LojaRepo.GetAllActiveAsync()).ToList();
            // Não carrega stock ainda — espera seleção de loja
        }
        else
        {
            await CarregarStock();
        }
        a_carregar = false;
    }

    private async Task OnLojaChanged()
    {
        if (lojaIdSelecionada == 0) { todos = new(); stockFiltrado = new(); alertas = Enumerable.Empty<StockAlertaDto>(); return; }
        a_carregar = true;
        await CarregarStock();
        a_carregar = false;
    }

    private async Task CarregarStock()
    {
        var lojaId = Session.IsGestorCadeia ? lojaIdSelecionada : (Session.LojaId ?? 0);
        if (lojaId == 0) return;

        todos = (await StockSvc.GetStockLojaAsync(lojaId)).ToList();
        alertas = await StockSvc.GetAlertasAsync(lojaId);
        Filtrar();
    }

    private void OnFiltroNomeInput(ChangeEventArgs e)
    {
        filtroNome = e.Value?.ToString() ?? "";
        Filtrar();
    }

    private void Filtrar()
    {
        var q = filtroNome.Trim();
        stockFiltrado = todos.Where(s =>
            (string.IsNullOrEmpty(q) ||
             s.NomeProduto.Contains(q, StringComparison.OrdinalIgnoreCase) ||
             s.CodigoProduto.Contains(q, StringComparison.OrdinalIgnoreCase) ||
             s.Categoria.Contains(q, StringComparison.OrdinalIgnoreCase)) &&
            filtroAlerta switch
            {
                "alerta"   => s.EmAlerta,
                "ok"       => !s.EmAlerta,
                "expirado" => s.DiasFimValidade.HasValue && s.DiasFimValidade.Value < 0,
                "aExpirar" => s.DiasFimValidade.HasValue && s.DiasFimValidade.Value >= 0 && s.DiasFimValidade.Value <= 30,
                _          => true
            }
        ).ToList();
    }

    private void AbrirAjuste(StockDto s) { produtoAjuste = s; ajusteVariacao = 0; ajusteMotivo = ""; erroAjuste = null; }

    private async Task ConfirmarAjuste()
    {
        if (string.IsNullOrWhiteSpace(ajusteMotivo)) { erroAjuste = "O motivo é obrigatório."; return; }
        a_ajuste = true; erroAjuste = null;
        var lojaId = Session.IsGestorCadeia ? lojaIdSelecionada : (Session.LojaId ?? 0);
        try
        {
            await StockSvc.AjustarStockAsync(lojaId, produtoAjuste!.ProdutoId, ajusteVariacao, ajusteMotivo, Session.UserId!);
            produtoAjuste = null;
            await CarregarStock();
        }
        catch (Exception ex) { erroAjuste = ex.Message; }
        finally { a_ajuste = false; }
    }

    private void ExportarCsv() { /* TODO: gerar CSV */ }
}
