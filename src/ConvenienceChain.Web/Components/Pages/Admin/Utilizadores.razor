@page "/admin/utilizadores"
@using ConvenienceChain.Core.Entities
@using ConvenienceChain.Core.Interfaces
@using ConvenienceChain.Core.Enums
@using ConvenienceChain.Web.Services
@inject IUtilizadorService UtilSvc
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>Gestão de Utilizadores – SGCLC</PageTitle>

@if (!Session.IsAuthenticated || !Session.IsGestorCadeia) { Nav.NavigateTo("/dashboard"); return; }

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1><i class="bi bi-people me-2 text-primary"></i>Utilizadores</h1>
        <p class="text-muted mb-0">Gestão de contas de acesso ao sistema</p>
    </div>
    <button class="btn btn-primary" @onclick="() => { modalAtivo = true; editando = null; ResetForm(); }">
        <i class="bi bi-plus-lg me-1"></i>Novo Utilizador
    </button>
</div>

@if (!string.IsNullOrEmpty(mensagem))
{
    <div class="alert alert-success">@mensagem</div>
}

@if (a_carregar)
{
    <div class="d-flex justify-content-center my-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Papel</th>
                        <th>Loja</th>
                        <th>Estado</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in utilizadores)
                    {
                        <tr>
                            <td class="fw-medium">@u.Nome</td>
                            <td class="small text-muted">@u.Email</td>
                            <td><span class="badge bg-secondary">@u.Papel</span></td>
                            <td class="small">@(u.Loja?.Nome ?? "–")</td>
                            <td>
                                @if (u.Ativo)
                                { <span class="badge bg-success">Ativo</span> }
                                else
                                { <span class="badge bg-danger">Inativo</span> }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditarUtilizador(u)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                @if (u.Ativo)
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Desativar(u.Id)">
                                        <i class="bi bi-person-x"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- Modal Criar/Editar -->
@if (modalAtivo)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editando is null ? "Novo Utilizador" : "Editar Utilizador")</h5>
                    <button type="button" class="btn-close" @onclick="() => modalAtivo = false"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(erroModal))
                    {
                        <div class="alert alert-danger py-2">@erroModal</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Nome</label>
                        <input class="form-control" @bind="formNome" placeholder="Nome completo" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input class="form-control" type="email" @bind="formEmail" placeholder="email@quickmart.pt" />
                    </div>
                    @if (editando is null)
                    {
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input class="form-control" type="password" @bind="formPassword" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Papel</label>
                        <select class="form-select" @bind="formPapel">
                            @foreach (var p in Enum.GetValues<PapelUtilizador>())
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => modalAtivo = false">Cancelar</button>
                    <button class="btn btn-primary" @onclick="Guardar" disabled="@a_guardar">
                        @if (a_guardar) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Utilizador> utilizadores = new();
    private bool a_carregar = true;
    private bool modalAtivo;
    private bool a_guardar;
    private Utilizador? editando;
    private string? mensagem;
    private string? erroModal;

    // Form fields
    private string formNome = "";
    private string formEmail = "";
    private string formPassword = "";
    private PapelUtilizador formPapel = PapelUtilizador.Funcionario;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsAuthenticated || !Session.IsGestorCadeia) return;
        utilizadores = (await UtilSvc.GetAllAsync()).ToList();
        a_carregar = false;
    }

    private void ResetForm() { formNome = ""; formEmail = ""; formPassword = ""; formPapel = PapelUtilizador.Funcionario; erroModal = null; }

    private void EditarUtilizador(Utilizador u)
    {
        editando = u;
        formNome = u.Nome;
        formEmail = u.Email;
        formPapel = u.Papel;
        erroModal = null;
        modalAtivo = true;
    }

    private async Task Guardar()
    {
        erroModal = null;
        if (string.IsNullOrWhiteSpace(formNome)) { erroModal = "Nome é obrigatório."; return; }
        if (string.IsNullOrWhiteSpace(formEmail)) { erroModal = "Email é obrigatório."; return; }
        if (editando is null && string.IsNullOrWhiteSpace(formPassword)) { erroModal = "Password é obrigatória."; return; }

        a_guardar = true;
        try
        {
            if (editando is null)
            {
                await UtilSvc.CreateAsync(new Core.DTOs.CreateUtilizadorDto(formNome, formEmail, formPassword, formPapel, null));
                mensagem = $"Utilizador '{formNome}' criado com sucesso.";
            }
            else
            {
                await UtilSvc.UpdateAsync(editando.Id, new Core.DTOs.UpdateUtilizadorDto(formNome, formPapel, editando.LojaId));
                mensagem = $"Utilizador '{formNome}' atualizado.";
            }
            utilizadores = (await UtilSvc.GetAllAsync()).ToList();
            modalAtivo = false;
        }
        catch (Exception ex)
        {
            erroModal = ex.Message;
        }
        a_guardar = false;
    }

    private async Task Desativar(string id)
    {
        await UtilSvc.DeactivateAsync(id);
        utilizadores = (await UtilSvc.GetAllAsync()).ToList();
        mensagem = "Utilizador desativado.";
    }
}
